{
  "apiVersion": 3,
  "category": "theme",
  "icon": "screenoptions",
  "editorScript": "jawad-dev-blocks-editor",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "recipient": {
      "type": "string",
      "default": ""
    },
    "formProvider": {
      "type": "string",
      "default": "builtin"
    },
    "gravityFormId": {
      "type": "number",
      "default": 0
    },
    "modalTitle": {
      "type": "string",
      "default": "Start a project request"
    },
    "modalSubtitle": {
      "type": "string",
      "default": "Tell me what you need and I’ll reply with next steps."
    },
    "gravityEyebrow": {
      "type": "string",
      "default": "> project_request"
    },
    "gravityServiceParam": {
      "type": "string",
      "default": "service"
    },
    "gravityBudgetParam": {
      "type": "string",
      "default": "budget"
    },
    "gravityTimelineParam": {
      "type": "string",
      "default": "timeline"
    }
  },
  "name": "jawad-dev/contact-modal",
  "title": "JD Contact Modal",
  "description": "Editable Contact Modal section for the Jawad Dev theme.",
  "textdomain": "jawad-dev"
}
