{
  "apiVersion": 3,
  "category": "theme",
  "icon": "screenoptions",
  "editorScript": "jawad-dev-blocks-editor",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "eyebrow": {
      "type": "string",
      "default": "// PORTFOLIO"
    },
    "title": {
      "type": "string",
      "default": "Recent Website Work"
    },
    "description": {
      "type": "string",
      "default": "A few representative WordPress builds, optimization projects, and WooCommerce improvements."
    },
    "postsToShow": {
      "type": "number",
      "default": 4
    }
  },
  "name": "jawad-dev/projects",
  "title": "JD Projects",
  "description": "Editable Projects section for the Jawad Dev theme.",
  "textdomain": "jawad-dev"
}
