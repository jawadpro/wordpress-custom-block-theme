{
  "apiVersion": 3,
  "category": "theme",
  "icon": "screenoptions",
  "editorScript": "jawad-dev-blocks-editor",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "brand": {
      "type": "string",
      "default": "jawad.dev"
    },
    "ctaText": {
      "type": "string",
      "default": "Hire Me"
    },
    "showServicesMega": {
      "type": "boolean",
      "default": true
    },
    "navLinks": {
      "type": "array",
      "default": [
        { "label": "Work", "url": "#work" },
        { "label": "Process", "url": "#process" },
        { "label": "FAQ", "url": "#faq" },
        { "label": "Blog", "url": "/blog/" },
        { "label": "Check Your Website", "url": "/wordpress-website-health-check/" }
      ]
    }
  },
  "name": "jawad-dev/site-header",
  "title": "JD Primary Header",
  "description": "Editable primary header and navigation for the Jawad Dev theme.",
  "textdomain": "jawad-dev"
}
